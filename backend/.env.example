# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

# Database — choose one:
#   SQLite (local dev, no extra setup):
DATABASE_URL=sqlite:///scheduler.sqlite3
#   PostgreSQL (production, e.g. Render):
# DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<dbname>

# Flask secret key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret-key

# CORS origin for frontend (adjust as needed)
CORS_ORIGIN=http://localhost:5173

# Session security
SESSION_TIMEOUT_MINUTES=30
SESSION_COOKIE_SECURE=0

# CSRF protection (set to 1 for enabled, 0 to disable)
CSRF_PROTECT_ENABLED=1

# Login/API rate limit policy
LOGIN_RATE_LIMIT=5 per minute

# Password policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_COMPLEXITY=0

# Flask-Limiter backend (memory:// for local dev)
RATELIMIT_STORAGE_URI=memory://

# Optional error tracking
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Log verbosity
LOG_LEVEL=INFO

# Optional: set to 'production' in deployed environment
FLASK_ENV=development
